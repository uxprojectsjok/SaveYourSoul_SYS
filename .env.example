# SaveYourSoul SYS — Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.

# Anthropic API key for Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Master key for HMAC-SHA256 soul_cert signing — generate with: openssl rand -hex 32
SOUL_MASTER_KEY=your-32-char-hex-secret

# API signing key for request validation
API_SIGNING_KEY=your-signing-key

# Set to "true" to allow new soul creation (default: false = invite-only)
ALLOW_CREATE_SOUL=false

# Reown / WalletConnect Project ID (https://cloud.reown.com)
WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
NUXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your-walletconnect-project-id

# WaveSpeed AI key for image/video generation (optional)
WAVESPEED_KEY=your-wavespeed-key
